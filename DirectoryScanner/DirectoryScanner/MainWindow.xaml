<Window x:Class="DirectoryScanner.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DirectoryScanner.WPF"
        mc:Ignorable="d"
        Title="Directory Scanner" Height="500" Width="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}" Width="350" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Button Content="..." Command="{Binding BrowseCommand}" Width="30" Margin="0,0,10,0"/>
            <Button Content="Сканировать" Command="{Binding ScanCommand}" Width="100" Margin="0,0,5,0"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="100"/>
        </StackPanel>

        <TreeView Grid.Row="1" ItemsSource="{Binding RootNode.Children}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="Icon" Text="📄" Margin="0,0,5,0"/>

                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding Size, StringFormat='({0} байт,'}" Margin="0,0,5,0" Foreground="Gray"/>
                        <TextBlock Text="{Binding Percentage, StringFormat={}{0:P1})}" Foreground="Blue"/>
                    </StackPanel>

                    <HierarchicalDataTemplate.Triggers>
                        <DataTrigger Binding="{Binding Type}" Value="Directory">
                            <Setter TargetName="Icon" Property="Text" Value="📁"/>
                        </DataTrigger>
                    </HierarchicalDataTemplate.Triggers>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>   
    </Grid>
</Window>